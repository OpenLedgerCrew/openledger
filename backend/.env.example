# Copy to .env and fill in as needed. Every variable here is optional — the server runs with
# in-memory seed data and deterministic (non-AI) fallbacks when nothing is set.

# Real DisburseFlow fork read API. Leave unset to serve the built-in seed data (see server.ts).
SDP_FORK_BASE_URL=

# Read-only API key for the fork above (Authorization: Bearer SDP_...), scoped to
# read:disbursements + read:payments. Required whenever SDP_FORK_BASE_URL is set.
SDP_API_KEY=

# Base URL used to build Stellar explorer deep links.
EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet

# Enables the AI-generated transparency summary and the LLM-powered chat assistant
# (GET /programmes/:id/ai-summary, POST /chat), via OpenRouter's chat completions API.
# Without this, both endpoints still work — they answer from a deterministic, data-driven
# fallback instead of calling the API.
OPENROUTER_API_KEY=

# Optional: override the default free OpenRouter model (google/gemma-4-26b-a4b-it:free).
OPENROUTER_MODEL=

PORT=3001
HOST=0.0.0.0
